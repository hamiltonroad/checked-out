NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=checked_out
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Logging
# LOG_LEVEL=info

# Profanity Filter
# Optional: Comma-separated list of additional profane words to detect
# PROFANITY_WORDS_CUSTOM=word1,word2,word3

# Test harness flag
# WARNING: TEST_MODE must NEVER be enabled in development, staging, or production.
# When true, the rate limiter is replaced with a no-op middleware so parallel
# Playwright workers do not exhaust the strict tier. It is set ONLY by
# scripts/e2e-test.sh and scripts/smoke-test.sh during local automated test runs.
# The backend exits at startup if TEST_MODE=true and NODE_ENV=production.
TEST_MODE=false
