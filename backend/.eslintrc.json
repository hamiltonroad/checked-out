{
  "extends": ["airbnb-base", "prettier"],
  "env": {
    "node": true
  },
  "rules": {
    "no-console": "error",
    "consistent-return": "off",
    "no-underscore-dangle": ["error", { "allow": ["_id"] }],
    "max-lines": ["warn", { "max": 200, "skipBlankLines": true, "skipComments": true }],
    "no-restricted-syntax": [
      "error",
      {
        "selector": "Literal[value='welcome123']",
        "message": "[HARNESS-DEV-PASSWORD-LITERAL issue #230] Import DEV_PASSWORD from backend/src/config/auth.js — do not repeat the literal."
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.test.js", "**/__tests__/**/*.js"],
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
      },
      "env": {
        "node": true
      },
      "globals": {
        "describe": "readonly",
        "it": "readonly",
        "expect": "readonly",
        "beforeEach": "readonly",
        "afterEach": "readonly",
        "beforeAll": "readonly",
        "afterAll": "readonly",
        "vi": "readonly"
      },
      "rules": {
        "import/no-unresolved": "off",
        "import/extensions": "off",
        "import/no-extraneous-dependencies": "off",
        "import/newline-after-import": "off",
        "no-shadow": "off",
        "max-lines": "off"
      }
    },
    {
      "files": ["**/seeders/**/*.js", "**/seeders/data/**/*.js"],
      "rules": {
        "max-lines": "off"
      }
    },
    {
      "files": ["src/routes/**/*.js", "src/middlewares/**/*.js"],
      "rules": {
        "no-restricted-syntax": [
          "error",
          {
            "selector": "Literal[value=/^(admin|librarian|patron|staff|system_admin)$/]",
            "message": "Use role constants from src/config/roles.js (ROLES.ADMIN, etc.) instead of raw role string literals."
          },
          {
            "selector": "Literal[value='welcome123']",
            "message": "[HARNESS-DEV-PASSWORD-LITERAL issue #230] Import DEV_PASSWORD from backend/src/config/auth.js — do not repeat the literal."
          }
        ]
      }
    },
    {
      "files": ["src/config/roles.js"],
      "rules": {
        "no-restricted-syntax": [
          "error",
          {
            "selector": "Literal[value='welcome123']",
            "message": "[HARNESS-DEV-PASSWORD-LITERAL issue #230] Import DEV_PASSWORD from backend/src/config/auth.js — do not repeat the literal."
          }
        ]
      }
    },
    {
      "files": ["src/config/auth.js"],
      "rules": {
        "no-restricted-syntax": "off"
      }
    },
    {
      "files": [
        "src/services/**/*.js",
        "src/controllers/**/*.js",
        "src/middlewares/**/*.js"
      ],
      "excludedFiles": ["**/*.test.js"],
      "rules": {
        "no-magic-numbers": [
          "warn",
          {
            "ignore": [-1, 0, 1, 2],
            "ignoreArrayIndexes": true,
            "enforceConst": true,
            "detectObjects": false
          }
        ]
      }
    },
    {
      "files": ["vitest.config.js"],
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
      },
      "rules": {
        "import/no-unresolved": "off",
        "import/no-extraneous-dependencies": "off"
      }
    }
  ]
}
